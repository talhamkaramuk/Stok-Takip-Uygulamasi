POSTGRES_DB=stokio
POSTGRES_PORT=5432
POSTGRES_USER=stokio
POSTGRES_PASSWORD=change_this_dev_password
STOKIO_CONNECTION_STRING=Host=postgres;Port=5432;Database=stokio;Username=stokio;Password=change_this_dev_password
STOKIO_JWT_SIGNING_KEY=replace-with-a-random-64-byte-production-secret
STOKIO_ACCESS_TOKEN_MINUTES=15
STOKIO_REFRESH_TOKEN_DAYS=14
STOKIO_ENSURE_CREATED=true
STOKIO_APPLY_DEVELOPMENT_SCHEMA_PATCHES=true
STOKIO_SEED_DEVELOPMENT_DATA=true
STOKIO_EXPORTS_STORAGE_PATH=/var/lib/stokio/export-files
STOKIO_EXPORT_JOB_LOCK_TIMEOUT_SECONDS=900
STOKIO_EXPORT_WORKER_IDLE_DELAY_MILLISECONDS=2000
STOKIO_EXPORT_RETRY_BACKOFF_BASE_SECONDS=30
STOKIO_EXPORT_RETRY_BACKOFF_MAX_SECONDS=900
STOKIO_EXPORT_CLEANUP_INTERVAL_MINUTES=30
STOKIO_EXPORT_COMPLETED_RETENTION_DAYS=7
VITE_API_BASE_URL=http://localhost:8080
VITE_ENABLE_DEMO_CREDENTIALS=false
