{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=stokio;Username=stokio;Password=stokio_dev_password"
  },
  "Database": {
    "EnsureCreated": false,
    "ApplyDevelopmentSchemaPatches": false,
    "SeedDevelopmentData": false
  },
  "Jwt": {
    "Issuer": "STOKIO.Api",
    "Audience": "STOKIO.Web",
    "SigningKey": "development-only-change-this-32-byte-minimum-key",
    "AccessTokenMinutes": 120
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
